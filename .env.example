# LLM provider — set at least one; use --provider flag to select (default: gemini)
GEMINI_API_KEY=your_gemini_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# HN filtering
MIN_SCORE=150
KEYWORDS=kubernetes,MCP,AI agents,GKE,agentic,LLM,open source AI,Claude
SCHEDULE_TIMES=08:00,17:00

# Slack (primary) — Slack incoming webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Ntfy (optional)
NTFY_TOPIC=your-topic-name
NTFY_BASE_URL=https://ntfy.sh

# SMS via Twilio (optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567
TWILIO_TO_NUMBER=+15559876543
