# LLM provider — set at least one; use --provider flag to select (default: gemini)
GEMINI_API_KEY=your_gemini_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# HN filtering
MIN_SCORE=150
KEYWORDS=kubernetes,MCP,AI agents,GKE,agentic,LLM,open source AI,Claude

# Schedule — simple (all runs share keywords above)
SCHEDULE_TIMES=08:00,17:00

# Schedule — named profiles (optional; overrides SCHEDULE_TIMES if any are defined)
# Each profile has its own time, keywords, and optional style hint for the LLM prompt.
# SCHEDULE_MORNING=08:00
# SCHEDULE_MORNING_KEYWORDS=LLM,AI agents,Claude,agentic
# SCHEDULE_MORNING_STYLE=concise morning briefing for a technical lead starting their day
# SCHEDULE_EVENING=17:00
# SCHEDULE_EVENING_KEYWORDS=kubernetes,GKE,open source AI,MCP
# SCHEDULE_EVENING_STYLE=end-of-day infrastructure and tooling roundup

# Slack (primary) — Slack incoming webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Ntfy (optional) — install the ntfy app and subscribe to your topic for push notifications
# Priority: 1=min 2=low 3=default 4=high 5=urgent
NTFY_TOPIC=your-topic-name
NTFY_BASE_URL=https://ntfy.sh
# NTFY_PRIORITY=4

# SMS via Twilio (optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567
TWILIO_TO_NUMBER=+15559876543

# Error alerting — channel for failure notifications (ntfy, slack, sms)
# If unset, falls back to the first available configured delivery channel.
# ALERT_CHANNEL=ntfy
